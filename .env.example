# SEO Crawler MCP — Environment Configuration
# Copy this to .env and fill in your values.

# --- Required for PageSpeed Insights audits ---
# Get a free API key: https://developers.google.com/speed/docs/insights/v5/get-started
# SEO_CRAWLER_PSI_API_KEY=your_google_psi_api_key

# Enable desktop PSI audits in addition to mobile (doubles API calls)
# SEO_CRAWLER_PSI_DESKTOP=true

# --- Optional: LanguageTool for spelling/grammar checks ---
# Run locally via Docker: docker compose up -d languagetool
# SEO_CRAWLER_LANGUAGETOOL_URL=http://localhost:8010

# --- Database ---
# SEO_CRAWLER_DB_PATH=seo-crawler.db

# --- Crawl limits ---
# SEO_CRAWLER_MAX_PAGES=10000
# SEO_CRAWLER_MAX_DEPTH=50
# SEO_CRAWLER_SCOPE_MODE=registrable_domain

# --- Rendering ---
# SEO_CRAWLER_RENDER_MODE=hybrid
# SEO_CRAWLER_RENDER_PROVIDER=auto
# SEO_CRAWLER_MAX_BROWSER_INSTANCES=2
# BROWSERBASE_API_KEY=your_browserbase_api_key
# BROWSERBASE_PROJECT_ID=your_browserbase_project_id

# --- Network ---
# SEO_CRAWLER_USER_AGENT=seo-crawler-mcp/0.1
# SEO_CRAWLER_REQUEST_TIMEOUT=10s
# SEO_CRAWLER_PER_HOST_CONCURRENCY=2
# SEO_CRAWLER_GLOBAL_CONCURRENCY=8
